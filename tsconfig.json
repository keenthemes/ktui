{
	"compilerOptions": {
		"lib": ["dom", "es2015"],
		"rootDir": "./src",
		"outDir": "./dist/",
		"sourceMap": true,
		"declaration": false,
		"strict": true,
		"strictNullChecks": false,
		"strictPropertyInitialization": false,
		"module": "commonjs",
		"target": "es5",
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleResolution": "node",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.spec.ts"
	]
}
